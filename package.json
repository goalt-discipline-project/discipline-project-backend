{
  "name": "backend",
  "author": {
    "name": "Davi Santana, Lucas Alguma Coisa Huss, Pedro Bernardo Pinto, Marcel Alguma Coisa"
  },
  "type": "module",
  "license": "UNLICENSED",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "preinstall": "node -e 'if(!/yarn.js$/.test(process.env.npm_execpath))throw new Error(\"USE YARN\")'",
    "lint": "eslint . --ext .ts,.js,.cjs,.mjs --ignore-pattern 'eslint.config.js'",
    "lint:fix": "eslint . --ext .ts,.js,.cjs,.mjs --fix --ignore-pattern 'eslint.config.js'",
    "format": "prettier --write .",
    "start:lefthook": "lefthook install",
    "migration:generate": "drizzle-kit generate",
    "migration:run": "drizzle-kit migrate"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.0",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "hono": "^4.9.6",
    "pg": "^8.16.3",
    "ulid": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^20.11.17",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-n": "^17.21.3",
    "eslint-plugin-prettier": "^5.5.4",
    "lefthook": "^1.12.4",
    "prettier": "^3.6.2",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.43.0"
  }
}
